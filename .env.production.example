# ===========================================
# AnonLink Production Environment Variables
# Copy to .env on the VM and fill in secrets
# ===========================================

# Domain
DOMAIN_NAME=anonlink.online

# PostgreSQL
POSTGRES_DB=anondb
POSTGRES_USER=anonuser
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_strong_db_password
DB_NAME=anonchat

# Backend
JWT_SECRET=CHANGE_ME_random_64_char_string
REFRESH_TOKEN_SECRET=CHANGE_ME_another_random_64_char_string

# COTURN
COTURN_SHARED_SECRET=CHANGE_ME_coturn_shared_secret

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://anonlink.online/api/v1/auth/google/callback

# Cloudflare Turnstile CAPTCHA
RECAPTCHA_SECRET_KEY=your-turnstile-secret-key
